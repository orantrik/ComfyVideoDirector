{
  "_node_pack": "comfyui-kokoro (github.com/stavsap/comfyui-kokoro)",
  "_class_types_used": ["KokoroSpeaker", "KokoroGenerator", "SaveAudio"],
  "_controller_patches": {
    "node_1_KokoroSpeaker":   "inputs.speaker_name <- kokoro_voice preset",
    "node_2_KokoroGenerator": "inputs.text         <- audio_prompt text",
    "node_3_SaveAudio":       "inputs.filename_prefix <- scene voiceover prefix"
  },
  "_note": [
    "Models and voices download automatically on first ComfyUI run.",
    "No manual model files needed.",
    "Good female English voices: af_heart, af_bella, af_nova, bf_emma, bf_alice.",
    "Change --kokoro-voice CLI flag to switch presets."
  ],
  "1": {
    "class_type": "KokoroSpeaker",
    "inputs": {
      "speaker_name": "af_heart"
    }
  },
  "2": {
    "class_type": "KokoroGenerator",
    "inputs": {
      "text": "Placeholder. Controller patches this field with the scene audio prompt.",
      "speaker": ["1", 0],
      "speed": 1.0,
      "lang": "English"
    }
  },
  "3": {
    "class_type": "SaveAudio",
    "inputs": {
      "filename_prefix": "voiceover",
      "audio": ["2", 0]
    }
  }
}
