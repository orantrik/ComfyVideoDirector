{
  "_note": [
    "Stage M — LTX-2 lip-sync video generation.",
    "This recipe is the API-format driver for the LipSync_AutoTour_ORIGINAL_DO_NOT_EDIT.json",
    "workflow. Nodes that the controller patches at runtime are documented below.",
    "",
    "PATCH MAP (controller fills these before queuing):",
    "  node 304  CLIPTextEncode          inputs.text           <- reconciled positive prompt",
    "  node 315  CLIPTextEncode          inputs.text           <- negative prompt",
    "  node 436  AIDirectorLoadFrame     inputs.image_path     <- abs path to renders/hero_locked.png",
    "  node 414  LoadAudio               inputs.audio          <- uploaded voiceover filename",
    "  node 273  SaveVideo               inputs.filename_prefix <- scene_XX/video/scene",
    "  node 418  TrimAudioDuration       inputs.duration       <- clip duration in seconds (float)",
    "",
    "FIRST RUN: the recipe graph below is pre-populated with conservative default values.",
    "If ComfyUI can open LipSync_AutoTour_ORIGINAL_DO_NOT_EDIT.json, export it via",
    "Workflow -> Export (API Format) and replace the contents of this file from node '336'",
    "onwards to get the full sampling chain with upscaling passes.",
    "",
    "The minimal graph below runs ONE sampling pass at 768x512, producing a short .mp4.",
    "It is enough to validate the Stage M pipeline end-to-end."
  ],
  "_patch_nodes": {
    "304": "CLIPTextEncode (positive) — patch inputs.text",
    "315": "CLIPTextEncode (negative) — patch inputs.text",
    "414": "LoadAudio                  — patch inputs.audio (ComfyUI stored filename)",
    "418": "TrimAudioDuration          — patch inputs.duration (seconds, float)",
    "436": "AIDirectorLoadFrame        — patch inputs.image_path (abs path to hero_locked.png)",
    "273": "SaveVideo                  — patch inputs.filename_prefix"
  },
  "_lora_models": {
    "unet":   "ltx-2-3-22b-dev_transformer_only_fp8_input_scaled.safetensors",
    "lora1":  "ltx-2.3-22b-distilled-lora-384.safetensors",
    "lora2":  "ltx-2-19b-lora-camera-control-static.safetensors",
    "icLora": "ltxv-098-ic-lora-detailer-comfyui.safetensors",
    "vVae":   "LTX23_video_vae_bf16.safetensors",
    "aVae":   "LTX23_audio_vae_bf16.safetensors",
    "clip1":  "gemma_3_12B_it_fp8_e4m3fn.safetensors",
    "clip2":  "ltx-2.3_text_projection_bf16.safetensors",
    "latUp":  "ltx-2.3-spatial-upscaler-x2-1.0.safetensors",
    "melRo":  "MelBandRoformer_fp16.safetensors"
  },
  "336": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "ltx-2-3-22b-dev_transformer_only_fp8_input_scaled.safetensors",
      "weight_dtype": "default"
    }
  },
  "337": {
    "class_type": "LTXVChunkFeedForward",
    "inputs": {
      "model": ["336", 0],
      "chunks": 15,
      "dim_threshold": 4352
    }
  },
  "341": {
    "class_type": "LoraLoaderModelOnly",
    "inputs": {
      "model": ["337", 0],
      "lora_name": "ltx-2.3-22b-distilled-lora-384.safetensors",
      "strength_model": 0.5
    }
  },
  "340": {
    "class_type": "LTX2AttentionTunerPatch",
    "inputs": {
      "model": ["341", 0],
      "blocks": "",
      "video_scale": 1,
      "audio_scale": 1,
      "audio_to_video_scale": 1,
      "video_to_audio_scale": 1,
      "triton_kernels": true
    }
  },
  "430": {
    "class_type": "LoraLoaderModelOnly",
    "inputs": {
      "model": ["340", 0],
      "lora_name": "ltx-2-19b-lora-camera-control-static.safetensors",
      "strength_model": 1
    }
  },
  "345": {
    "class_type": "PathchSageAttentionKJ",
    "inputs": {
      "model": ["430", 0],
      "sage_attention": "auto",
      "allow_compile": false
    }
  },
  "322": {
    "class_type": "LTX2LoraLoaderAdvanced",
    "inputs": {
      "model": ["345", 0],
      "lora_name": "ltxv-098-ic-lora-detailer-comfyui.safetensors",
      "strength_model": 0.75,
      "video": 1,
      "video_to_audio": 1,
      "audio": 1,
      "audio_to_video": 1,
      "other": 1
    }
  },
  "315": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["344", 0],
      "text": "pc game, console game, video game, cartoon, childish, ugly, blurry, low quality"
    }
  },
  "331": {
    "class_type": "LTX2_NAG",
    "inputs": {
      "model": ["322", 0],
      "nag_cond_video": ["315", 0],
      "nag_cond_audio": ["315", 0],
      "nag_scale": 11,
      "nag_alpha": 0.25,
      "nag_tau": 2.5,
      "inplace": true
    }
